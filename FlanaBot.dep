@client.command()
async def clear(contexto, arg):
    try:
        cantidad = int(arg)
        if cantidad < 0:
            raise ValueError
        mensajes = await contexto.message.channel.history(limit=cantidad + 1).flatten()
        await contexto.message.channel.delete_messages(mensajes)
    except (ValueError, BadArgument):
        await contexto.message.delete()
    except ClientException:
        await contexto.send('El máximo es 100 primo')


client.run(TOKEN)
